<UserControl x:Class="DisplayProfileManager.ScanOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#CC0F1216"
             Visibility="Collapsed"
             IsHitTestVisible="False">
    <UserControl.Resources>
        <Storyboard x:Key="SpinAnim" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="SpinRotate" Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:0.85">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="ScanLoop" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="RingPulse" Storyboard.TargetProperty="Opacity"
                             From="0.35" To="0.85" Duration="0:0:0.9" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BarFill" Storyboard.TargetProperty="Width"
                             From="24" To="160" Duration="0:0:1.4" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Border x:Name="Panel" HorizontalAlignment="Center" VerticalAlignment="Center"
            MinWidth="280" Padding="28,26" CornerRadius="16"
            Background="{DynamicResource PanelBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="2" Opacity="0.45" Color="#000000"/>
        </Border.Effect>
        <StackPanel HorizontalAlignment="Center">
            <Grid Width="56" Height="56" Margin="0,0,0,18" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <RotateTransform x:Name="SpinRotate"/>
                </Grid.RenderTransform>
                <Ellipse x:Name="RingPulse" Width="56" Height="56"
                         Stroke="{DynamicResource AccentBrush}" StrokeThickness="2.5" Opacity="0.5"
                         StrokeDashArray="2.2 1.4"/>
                <Ellipse Width="40" Height="40" Stroke="{DynamicResource BorderBrush}" StrokeThickness="1.5"/>
                <!-- Search / radar icon -->
                <Path Width="18" Height="18" Stretch="Uniform" Fill="{DynamicResource TextBrush}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M9.5,3A6.5,6.5 0 1,0 16,9.5C16,11.1 15.4,12.55 14.45,13.66L19,18.2 17.8,19.4 13.25,14.85A6.5,6.5 0 0,1 9.5,16 6.5,6.5 0 0,1 3,9.5 6.5,6.5 0 0,1 9.5,3M9.5,5A4.5,4.5 0 0,0 5,9.5 4.5,4.5 0 0,0 9.5,14 4.5,4.5 0 0,0 14,9.5 4.5,4.5 0 0,0 9.5,5Z"/>
            </Grid>

            <TextBlock Text="Scanning" FontWeight="SemiBold" FontSize="15"
                       Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="StatusText" Text="Looking for games…"
                       Foreground="{DynamicResource MutedBrush}" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,6,0,16" TextAlignment="Center"/>

            <Border Height="3" Width="160" CornerRadius="2" Background="{DynamicResource TrackBrush}"
                    HorizontalAlignment="Center" ClipToBounds="True">
                <Border x:Name="BarFill" Height="3" Width="40" CornerRadius="2"
                        HorizontalAlignment="Left" Background="{DynamicResource AccentBrush}"/>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
