<UserControl x:Class="DisplayProfileManager.ScanOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#D9100C0E"
             Visibility="Collapsed"
             IsHitTestVisible="False">
    <UserControl.Resources>
        <Storyboard x:Key="ScanLoop" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ArtFloat" Storyboard.TargetProperty="Y"
                             From="0" To="-6" Duration="0:0:1.6" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity"
                             From="0.25" To="0.6" Duration="0:0:1.2" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Shimmer" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-120" To="320" Duration="0:0:1.8"/>
            <DoubleAnimation Storyboard.TargetName="CardBreath" Storyboard.TargetProperty="ScaleX"
                             From="1" To="1.012" Duration="0:0:1.5" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardBreath" Storyboard.TargetProperty="ScaleY"
                             From="1" To="1.012" Duration="0:0:1.5" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="SpinAnim" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="SpinRotate" Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:1.1"/>
        </Storyboard>
    </UserControl.Resources>

    <Border x:Name="Panel" HorizontalAlignment="Center" VerticalAlignment="Center"
            Width="420" Padding="18,16" CornerRadius="16"
            BorderBrush="#4A3340" BorderThickness="1"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="CardBreath"/>
        </Border.RenderTransform>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#22181E" Offset="0"/>
                <GradientStop Color="#151015" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="4" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Ellipse x:Name="Glow" Width="300" Height="140" Opacity="0.35"
                     HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#77C45C84" Offset="0"/>
                        <GradientStop Color="#00C45C84" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <StackPanel>
                <Grid Height="190" Margin="0,0,0,10">
                    <Border CornerRadius="12" ClipToBounds="True">
                        <Image x:Name="Art" Stretch="UniformToFill"
                               RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <TranslateTransform x:Name="ArtFloat"/>
                            </Image.RenderTransform>
                        </Image>
                    </Border>

                    <Border Width="56" Height="56" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                            Margin="14,0,0,14" CornerRadius="28" Background="#BB120E11"
                            BorderBrush="#66E891A8" BorderThickness="1">
                        <Grid Width="36" Height="36" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <RotateTransform x:Name="SpinRotate"/>
                            </Grid.RenderTransform>
                            <Ellipse Width="36" Height="36" Stroke="#33E891A8" StrokeThickness="3"/>
                            <Path Stroke="#E891A8" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M 18,2 A 16,16 0 1 1 2,18"/>
                        </Grid>
                    </Border>
                </Grid>

                <TextBlock Text="Scanning for games" FontWeight="SemiBold" FontSize="15"
                           Foreground="#F8EAF0" HorizontalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="Looking through disks…"
                           Foreground="#B08A9A" FontSize="12" HorizontalAlignment="Center"
                           Margin="0,4,0,10" TextWrapping="Wrap" TextAlignment="Center"/>

                <Border Height="4" CornerRadius="2" Background="#2A1C24" ClipToBounds="True">
                    <Border Width="90" HorizontalAlignment="Left" CornerRadius="2"
                            x:Name="Shimmer">
                        <Border.RenderTransform>
                            <TranslateTransform X="-120"/>
                        </Border.RenderTransform>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#00E891A8" Offset="0"/>
                                <GradientStop Color="#E891A8" Offset="0.5"/>
                                <GradientStop Color="#00E891A8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
