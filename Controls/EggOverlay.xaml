<UserControl x:Class="DisplayProfileManager.EggOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Visibility="Collapsed"
             IsHitTestVisible="False">
    <UserControl.Resources>
        <Storyboard x:Key="EggIn">
            <DoubleAnimation Storyboard.TargetName="Card" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.28">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX"
                             From="0.9" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY"
                             From="0.9" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ArtFloat" Storyboard.TargetProperty="Y"
                             From="16" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity"
                             From="0.15" To="0.5" Duration="0:0:0.5" AutoReverse="True"/>
        </Storyboard>
        <Storyboard x:Key="EggOut">
            <DoubleAnimation Storyboard.TargetName="Card" Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX"
                             From="1" To="1.04" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY"
                             From="1" To="1.04" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="Root" Opacity="1" IsHitTestVisible="False">
        <!-- Dimmer: never steals clicks -->
        <Border Background="#990E0A0C" IsHitTestVisible="False"/>
        <Border x:Name="Card"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="560" Height="320"
                CornerRadius="16" BorderBrush="#5A3A48" BorderThickness="1"
                Opacity="0" ClipToBounds="True" IsHitTestVisible="False"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform x:Name="CardScale" ScaleX="0.9" ScaleY="0.9"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="36" ShadowDepth="6" Opacity="0.55" Color="#000000"/>
            </Border.Effect>
            <Border.Background>
                <SolidColorBrush Color="#120E11"/>
            </Border.Background>
            <Grid>
                <Ellipse x:Name="Glow" Width="480" Height="220" Opacity="0.2"
                         HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#88C45C84" Offset="0"/>
                            <GradientStop Color="#00C45C84" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Image x:Name="Art"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"
                       RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <TranslateTransform x:Name="ArtFloat" Y="16"/>
                    </Image.RenderTransform>
                </Image>
            </Grid>
        </Border>
    </Grid>
</UserControl>
