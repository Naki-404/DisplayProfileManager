<UserControl x:Class="DisplayProfileManager.SaveOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Visibility="Collapsed"
             IsHitTestVisible="False">
    <UserControl.Resources>
        <Storyboard x:Key="SaveIn">
            <DoubleAnimation Storyboard.TargetName="Card" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX"
                             From="0.88" To="1" Duration="0:0:0.28">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.35"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY"
                             From="0.88" To="1" Duration="0:0:0.28">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.35"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CheckScale" Storyboard.TargetProperty="ScaleX"
                             From="0.4" To="1" Duration="0:0:0.32" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.5"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CheckScale" Storyboard.TargetProperty="ScaleY"
                             From="0.4" To="1" Duration="0:0:0.32" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.5"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CheckPath" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2" BeginTime="0:0:0.1"/>
        </Storyboard>
        <Storyboard x:Key="SaveOut">
            <DoubleAnimation Storyboard.TargetName="Card" Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX"
                             From="1" To="0.94" Duration="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY"
                             From="1" To="0.94" Duration="0:0:0.18"/>
        </Storyboard>
    </UserControl.Resources>

    <Border x:Name="Card" HorizontalAlignment="Center" VerticalAlignment="Bottom"
            Margin="0,0,0,56" MinWidth="220" Padding="22,18" CornerRadius="14"
            Background="{DynamicResource PanelBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Opacity="0"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="CardScale" ScaleX="0.88" ScaleY="0.88"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="2" Opacity="0.4" Color="#000000"/>
        </Border.Effect>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Grid Width="36" Height="36" Margin="0,0,14,0" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <ScaleTransform x:Name="CheckScale" ScaleX="0.4" ScaleY="0.4"/>
                </Grid.RenderTransform>
                <Ellipse Fill="{DynamicResource AccentBrush}"/>
                <Path x:Name="CheckPath" Opacity="0"
                      Stroke="{DynamicResource AccentButtonTextBrush}" StrokeThickness="2.4"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                      Width="16" Height="12" Stretch="Uniform"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M1,6 L6,11 L15,1"/>
            </Grid>
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" Text="Saved" FontWeight="SemiBold" FontSize="14"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBlock Text="Changes written" Foreground="{DynamicResource MutedBrush}" FontSize="11"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
