<Window x:Class="DisplayProfileManager.CompanionEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Companion" Height="460" Width="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="Executable path (.exe only)" Foreground="{DynamicResource MutedBrush}"/>
            <Grid Margin="0,4,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtPath"/>
                <Button Grid.Column="1" Content="…" Width="36" Margin="6,0,0,0" Style="{StaticResource GhostButton}" Click="Browse_Click"/>
            </Grid>

            <TextBlock Text="Launch arguments (optional)" Foreground="{DynamicResource MutedBrush}"/>
            <TextBox x:Name="TxtArgs" Margin="0,4,0,4"
                     ToolTip="Example: -launchapp elkagffjjeonbcmfpdndkckppafabjeklmdidong"/>
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10" FontSize="11" Foreground="{DynamicResource MutedBrush}"
                       Text="Example: -launchapp elkagffjjeonbcmfpdndkckppafabjeklmdidong"/>

            <TextBlock Text="Launch mode" Foreground="{DynamicResource MutedBrush}"/>
            <ComboBox x:Name="CmbLaunch" Margin="0,4,0,10">
                <ComboBoxItem Content="direct"/>
                <ComboBoxItem Content="scheduledTask"/>
            </ComboBox>

            <TextBlock Text="Scheduled task name (letters, digits, . - \ only)" Foreground="{DynamicResource MutedBrush}"/>
            <TextBox x:Name="TxtTask" Margin="0,4,0,10"/>

            <TextBlock Text="On stop (companion process only — never the game)" Foreground="{DynamicResource MutedBrush}"/>
            <ComboBox x:Name="CmbOnStop" Margin="0,4,0,10">
                <ComboBoxItem Content="closeThenKill"/>
                <ComboBoxItem Content="close"/>
                <ComboBoxItem Content="kill"/>
                <ComboBoxItem Content="none"/>
            </ComboBox>

            <TextBlock TextWrapping="Wrap" Margin="0,4,0,8" Foreground="{DynamicResource MutedBrush}"
                       Text="Companions are separate tools. Stop never sends global keyboard input and never injects into the game."/>

            <CheckBox x:Name="ChkDismiss" Content="Dismiss startup dialogs (click No)"/>
            <CheckBox x:Name="ChkTray" Content="Minimize to tray after launch"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource GhostButton}" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="OK" Style="{StaticResource AccentButton}" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
