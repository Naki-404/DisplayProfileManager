<UserControl x:Class="DisplayProfileManager.SaveOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Visibility="Collapsed"
             IsHitTestVisible="False">
    <UserControl.Resources>
        <Storyboard x:Key="SaveIn">
            <DoubleAnimation Storyboard.TargetName="Card" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX"
                             From="0.92" To="1" Duration="0:0:0.28">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY"
                             From="0.92" To="1" Duration="0:0:0.28">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ArtFloat" Storyboard.TargetProperty="Y"
                             From="12" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity"
                             From="0.2" To="0.55" Duration="0:0:0.5" AutoReverse="True"/>
        </Storyboard>
        <Storyboard x:Key="SaveOut">
            <DoubleAnimation Storyboard.TargetName="Card" Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX"
                             From="1" To="1.04" Duration="0:0:0.25"/>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY"
                             From="1" To="1.04" Duration="0:0:0.25"/>
        </Storyboard>
    </UserControl.Resources>

    <Border x:Name="Card" HorizontalAlignment="Center" VerticalAlignment="Bottom"
            Margin="0,0,0,48" Width="300" Padding="14,12" CornerRadius="14"
            BorderBrush="#4A3340" BorderThickness="1" Opacity="0"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="CardScale" ScaleX="0.92" ScaleY="0.92"/>
        </Border.RenderTransform>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#24181E" Offset="0"/>
                <GradientStop Color="#151015" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="3" Opacity="0.45" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Ellipse x:Name="Glow" Width="220" Height="90" Opacity="0.3"
                     HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,0">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#88C45C84" Offset="0"/>
                        <GradientStop Color="#00C45C84" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <StackPanel>
                <Border Height="120" CornerRadius="10" ClipToBounds="True" Margin="0,0,0,8">
                    <Image x:Name="Art" Stretch="UniformToFill" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <TranslateTransform x:Name="ArtFloat" Y="12"/>
                        </Image.RenderTransform>
                    </Image>
                </Border>
                <TextBlock x:Name="TitleText" Text="Saved" FontWeight="SemiBold" FontSize="14"
                           Foreground="#F8EAF0" HorizontalAlignment="Center"/>
                <TextBlock Text="Profile tucked on the shelf"
                           Foreground="#B08A9A" FontSize="11"
                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
