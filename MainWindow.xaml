<Window x:Class="DisplayProfileManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:DisplayProfileManager"
        Title="Display Profile Manager"
        Height="740" Width="1080"
        MinHeight="580" MinWidth="880"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="ChromeRoot" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
            Background="{DynamicResource BgBrush}" Opacity="0">
    <Grid Background="{DynamicResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Grid Grid.Row="0" Background="{DynamicResource TitleBarBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock x:Name="TitleAppName" Text="Display Profile Manager" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="Monitoring" Margin="12,0,0,0" FontSize="11"
                           Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                <Border x:Name="ActivePill" Margin="12,0,0,0" Padding="10,3" CornerRadius="10"
                        Background="{DynamicResource PillBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="ActiveHeaderText" Text="No game active" FontSize="11"
                               Foreground="{DynamicResource AccentHoverBrush}"/>
                </Border>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Stretch">
                <Button x:Name="BtnSettingsCaption" Style="{StaticResource CaptionButton}" Click="Settings_Click"
                        MinWidth="72" Width="Auto" Padding="10,0"
                        ToolTip="Settings" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock x:Name="TxtSettingsCaption" Text="Settings" FontSize="11"
                               Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                </Button>
                <Button Style="{StaticResource CaptionButton}" Click="Minimize_Click"
                        ToolTip="Minimize"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Width="10" Height="10" Stretch="Uniform" Stroke="{DynamicResource MutedBrush}" StrokeThickness="1.2"
                          Data="M0,5 L10,5"/>
                </Button>
                <Button Style="{StaticResource CaptionButton}" Click="Maximize_Click"
                        ToolTip="Maximize"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Width="10" Height="10" Stretch="Uniform" Stroke="{DynamicResource MutedBrush}" StrokeThickness="1.2"
                          Data="M1,1 H9 V9 H1 Z" Fill="Transparent"/>
                </Button>
                <Button Style="{StaticResource CaptionCloseButton}" Click="Close_Click"
                        ToolTip="Close"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Width="10" Height="10" Stretch="Uniform" Stroke="{DynamicResource MutedBrush}" StrokeThickness="1.2"
                          Data="M1,1 L9,9 M9,1 L1,9"/>
                </Button>
            </StackPanel>
        </Grid>

        <Grid x:Name="ContentRoot" Grid.Row="1" Margin="18,10,18,14" Background="{DynamicResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnApply" Content="Apply" Style="{StaticResource AccentButton}" Margin="0,0,8,0" Click="Apply_Click"
                        ToolTip="Apply Global defaults / selected profile / selected preset (depends on active tab)"/>
                <Button x:Name="BtnSave" Content="Save" Style="{StaticResource GhostButton}" Margin="0,0,8,0" Click="Save_Click"/>
                <Button x:Name="BtnReset" Content="Reset settings" Style="{StaticResource GhostButton}" Click="ResetSettings_Click"
                        ToolTip="Restore factory display settings (resolution + neutral color)"/>
            </StackPanel>
        </DockPanel>

        <local:TabBuddy x:Name="TabMascot" Grid.Row="1" Margin="0,0,0,6" Panel.ZIndex="50"/>
        <Grid Grid.Row="2">
            <TabControl x:Name="MainTabs">
            <TabItem x:Name="TabProfiles" Header="Profiles">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="270"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{DynamicResource PanelBrush}" CornerRadius="10" Padding="10">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                <TextBox x:Name="TxtSearch" Margin="0,0,0,8" TextChanged="Search_Changed"
                                         ToolTip="Search games…"/>
                                <Button x:Name="BtnScan" Content="Scan games" Style="{StaticResource AccentButton}"
                                        HorizontalAlignment="Stretch" Click="ScanGames_Click" Margin="0,0,0,6"
                                        ToolTip="Find installed and running known games"/>
                                <Button x:Name="BtnAddManual" Content="Add manually" Style="{StaticResource GhostButton}"
                                        HorizontalAlignment="Stretch" Click="AddProfile_Click"/>
                                <Button x:Name="BtnRestore" Content="Restore my games" Style="{StaticResource GhostButton}"
                                        HorizontalAlignment="Stretch" Margin="0,6,0,0" Click="RestoreCoreGames_Click"
                                        ToolTip="Add Valorant / PUBG / War Thunder / Tarkov if missing"/>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button x:Name="BtnDup" Content="Dup" Style="{StaticResource GhostButton}" Margin="0,0,6,0" Click="DupProfile_Click"/>
                                <Button x:Name="BtnDelete" Content="Delete" Style="{StaticResource GhostButton}" Click="DeleteProfile_Click"/>
                            </StackPanel>
                            <ListBox x:Name="ProfileList" SelectionChanged="ProfileList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8" Padding="8,7" Background="{Binding TileBrush}" MinHeight="48">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="36"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="32" Height="32" CornerRadius="7" Background="#66000000"
                                                        VerticalAlignment="Center">
                                                    <Grid>
                                                        <Image Source="{Binding Icon}" Width="28" Height="28"
                                                               Stretch="Uniform"
                                                               Visibility="{Binding Icon, Converter={StaticResource NullToVis}}"/>
                                                        <TextBlock Text="{Binding Glyph}" FontWeight="Bold" FontSize="12"
                                                                   Foreground="#F8EAF0" HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="{Binding Icon, Converter={StaticResource InvNullToVis}}"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#FFF8F4"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding ProcessName}" Foreground="#E8D0D8" FontSize="10"
                                                               Opacity="0.85" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden">
                        <Border Background="{DynamicResource PanelBrush}" CornerRadius="10" Padding="16">
                            <StackPanel x:Name="EditorPanel">
                                <TextBlock Text="Profile" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <CheckBox x:Name="ChkEnabled" Content="Enabled" Checked="EditorChanged" Unchecked="EditorChanged"/>

                                <TextBlock Text="Name" Margin="0,10,0,4" Foreground="{DynamicResource MutedBrush}"/>
                                <TextBox x:Name="TxtName" TextChanged="EditorChanged"/>

                                <TextBlock Text="Process (.exe)" Margin="0,10,0,4" Foreground="{DynamicResource MutedBrush}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtProcess" Grid.Column="0" TextChanged="EditorChanged"/>
                                    <Button Grid.Column="1" Content="Browse" Style="{StaticResource GhostButton}" Margin="6,0,0,0" Click="BrowseExe_Click"/>
                                    <Button Grid.Column="2" Content="Running..." Style="{StaticResource GhostButton}" Margin="6,0,0,0" Click="PickRunning_Click"/>
                                </Grid>

                                <Separator/>
                                <TextBlock Text="Display" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <CheckBox x:Name="ChkApplyRes" Content="Change resolution" Checked="EditorChanged" Unchecked="EditorChanged"/>
                                <ComboBox x:Name="CmbResolution" Margin="0,6,0,0" SelectionChanged="EditorChanged"/>
                                <TextBlock x:Name="LblDisplay" Text="Monitor" Margin="0,10,0,4" Foreground="{DynamicResource MutedBrush}"/>
                                <ComboBox x:Name="CmbDisplay" SelectionChanged="EditorChanged"/>
                                <CheckBox x:Name="ChkApplyPower" Content="Change power plan" Margin="0,12,0,0" Checked="EditorChanged" Unchecked="EditorChanged"/>
                                <ComboBox x:Name="CmbPower" Margin="0,6,0,0" SelectionChanged="EditorChanged">
                                    <ComboBoxItem Content="highPerformance" Tag="highPerformance"/>
                                    <ComboBoxItem Content="balanced" Tag="balanced"/>
                                    <ComboBoxItem Content="(don't change)" Tag=""/>
                                </ComboBox>

                                <Separator/>
                                <TextBlock Text="Color" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <CheckBox x:Name="ChkApplyColor" Content="Apply color with this profile" Checked="EditorChanged" Unchecked="EditorChanged"/>
                                <TextBlock x:Name="LblBrightness" Text="Brightness: 0.50" Margin="0,10,0,0" Foreground="{DynamicResource MutedBrush}"/>
                                <Slider x:Name="SldBrightness" Minimum="0" Maximum="1" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="ColorSlider_ValueChanged"/>
                                <TextBlock x:Name="LblContrast" Text="Contrast: 1.00" Margin="0,8,0,0" Foreground="{DynamicResource MutedBrush}"/>
                                <Slider x:Name="SldContrast" Minimum="0.5" Maximum="2" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="ColorSlider_ValueChanged"/>
                                <TextBlock x:Name="LblGamma" Text="Gamma: 1.00" Margin="0,8,0,0" Foreground="{DynamicResource MutedBrush}"/>
                                <Slider x:Name="SldGamma" Minimum="0.3" Maximum="3" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="ColorSlider_ValueChanged"/>

                                <Separator/>
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock Text="Companions" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Button Content="Add" Style="{StaticResource GhostButton}" HorizontalAlignment="Right" Click="AddCompanion_Click"/>
                                </DockPanel>
                                <ListBox x:Name="CompanionList" Height="100" DisplayMemberPath="Path"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="Edit" Style="{StaticResource GhostButton}" Margin="0,0,6,0" Click="EditCompanion_Click"/>
                                    <Button Content="Remove" Style="{StaticResource GhostButton}" Click="RemoveCompanion_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem x:Name="TabPresets" Header="Presets">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Game picker -->
                    <Border Grid.Column="0" Background="{DynamicResource PanelBrush}" CornerRadius="10" Padding="10">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Game" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ListBox x:Name="PresetGameList" SelectionChanged="PresetGameList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8" Padding="8,7" Background="{Binding TileBrush}" MinHeight="44">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="32"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="28" Height="28" CornerRadius="6" Background="#66000000">
                                                    <Grid>
                                                        <Image Source="{Binding Icon}" Width="24" Height="24"
                                                               Visibility="{Binding Icon, Converter={StaticResource NullToVis}}"/>
                                                        <TextBlock Text="{Binding Glyph}" FontWeight="Bold" FontSize="11"
                                                                   Foreground="#FFF8F4" HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="{Binding Icon, Converter={StaticResource InvNullToVis}}"/>
                                                    </Grid>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold"
                                                           Foreground="#FFF8F4" VerticalAlignment="Center" Margin="8,0,0,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2" Background="{DynamicResource PanelBrush}" CornerRadius="10" Padding="10">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" x:Name="LblPresetGame" Text="Presets"
                                       FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Add" Style="{StaticResource AccentButton}" Margin="0,0,6,0" Click="AddPreset_Click"/>
                                <Button Content="Delete" Style="{StaticResource GhostButton}" Click="DeletePreset_Click"/>
                            </StackPanel>
                            <ListBox x:Name="PresetList" SelectionChanged="PresetList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Summary}" Foreground="#B08A9A" FontSize="11"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <ScrollViewer Grid.Column="4" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden">
                        <Border Background="{DynamicResource PanelBrush}" CornerRadius="10" Padding="16">
                            <StackPanel x:Name="PresetEditor">
                                <TextBlock Text="Preset for this game" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock Text="Hotkeys work only while this game is running" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,12"/>

                                <TextBlock Text="Name" Foreground="{DynamicResource MutedBrush}"/>
                                <TextBox x:Name="TxtPresetName" Margin="0,4,0,10" TextChanged="PresetEditorChanged"/>

                                <TextBlock Text="Hotkey (click &amp; press)" Foreground="{DynamicResource MutedBrush}"/>
                                <TextBox x:Name="TxtPresetHotkey" Margin="0,4,0,10" PreviewKeyDown="HotkeyBox_PreviewKeyDown" TextChanged="PresetEditorChanged"/>

                                <CheckBox x:Name="ChkPresetRes" Content="Set resolution" Checked="PresetEditorChanged" Unchecked="PresetEditorChanged"/>
                                <ComboBox x:Name="CmbPresetRes" Margin="0,6,0,12" SelectionChanged="PresetEditorChanged"/>

                                <CheckBox x:Name="ChkPresetColor" Content="Set color" Checked="PresetEditorChanged" Unchecked="PresetEditorChanged"/>
                                <TextBlock x:Name="LblPresetB" Text="Brightness: 0.50" Margin="0,8,0,0" Foreground="{DynamicResource MutedBrush}"/>
                                <Slider x:Name="SldPresetB" Minimum="0" Maximum="1" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="PresetColor_ValueChanged"/>
                                <TextBlock x:Name="LblPresetC" Text="Contrast: 1.00" Margin="0,6,0,0" Foreground="{DynamicResource MutedBrush}"/>
                                <Slider x:Name="SldPresetC" Minimum="0.5" Maximum="2" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="PresetColor_ValueChanged"/>
                                <TextBlock x:Name="LblPresetG" Text="Gamma: 1.00" Margin="0,6,0,0" Foreground="{DynamicResource MutedBrush}"/>
                                <Slider x:Name="SldPresetG" Minimum="0.3" Maximum="3" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="PresetColor_ValueChanged"/>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem x:Name="TabGlobal" Header="Global">
                <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden">
                    <Border Background="{DynamicResource PanelBrush}" CornerRadius="10" Padding="16">
                        <StackPanel MaxWidth="620" HorizontalAlignment="Left">
                            <TextBlock Text="Defaults (no game running)" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <TextBlock Text="Default resolution" Foreground="{DynamicResource MutedBrush}"/>
                            <ComboBox x:Name="CmbDefaultRes" Margin="0,4,0,12"/>
                            <TextBlock Text="Default power plan" Foreground="{DynamicResource MutedBrush}"/>
                            <ComboBox x:Name="CmbDefaultPower" Margin="0,4,0,12">
                                <ComboBoxItem Content="balanced" IsSelected="True"/>
                                <ComboBoxItem Content="highPerformance"/>
                            </ComboBox>

                            <TextBlock Text="Default color" FontWeight="SemiBold" Margin="0,4,0,8"/>
                            <TextBlock x:Name="LblDefBrightness" Text="Brightness: 0.50" Foreground="{DynamicResource MutedBrush}"/>
                            <Slider x:Name="SldDefBrightness" Minimum="0" Maximum="1" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="DefColor_ValueChanged"/>
                            <TextBlock x:Name="LblDefContrast" Text="Contrast: 1.00" Foreground="{DynamicResource MutedBrush}"/>
                            <Slider x:Name="SldDefContrast" Minimum="0.5" Maximum="2" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="DefColor_ValueChanged"/>
                            <TextBlock x:Name="LblDefGamma" Text="Gamma: 1.00" Foreground="{DynamicResource MutedBrush}"/>
                            <Slider x:Name="SldDefGamma" Minimum="0.3" Maximum="3" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="DefColor_ValueChanged"/>

                            <Separator/>
                            <TextBlock Text="Adjustment hotkeys" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="Click a field and press a key combo. Esc / Backspace / Delete or Clear removes it."
                                       Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                    <RowDefinition/><RowDefinition/><RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Brightness +" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="HkBrightUp" Margin="0,4,8,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                                         ToolTip="Click, then press keys. Empty = disabled."/>
                                <Button Grid.Row="0" Grid.Column="2" Content="Clear" Style="{StaticResource GhostButton}" Padding="10,4"
                                        Margin="0,4,0,4" Click="ClearHotkey_Click" Tag="{Binding ElementName=HkBrightUp}"/>
                                <TextBlock Grid.Row="1" Text="Brightness -" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="HkBrightDown" Margin="0,4,8,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                                <Button Grid.Row="1" Grid.Column="2" Content="Clear" Style="{StaticResource GhostButton}" Padding="10,4"
                                        Margin="0,4,0,4" Click="ClearHotkey_Click" Tag="{Binding ElementName=HkBrightDown}"/>
                                <TextBlock Grid.Row="2" Text="Contrast +" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="HkContrastUp" Margin="0,4,8,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                                <Button Grid.Row="2" Grid.Column="2" Content="Clear" Style="{StaticResource GhostButton}" Padding="10,4"
                                        Margin="0,4,0,4" Click="ClearHotkey_Click" Tag="{Binding ElementName=HkContrastUp}"/>
                                <TextBlock Grid.Row="3" Text="Contrast -" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="1" x:Name="HkContrastDown" Margin="0,4,8,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                                <Button Grid.Row="3" Grid.Column="2" Content="Clear" Style="{StaticResource GhostButton}" Padding="10,4"
                                        Margin="0,4,0,4" Click="ClearHotkey_Click" Tag="{Binding ElementName=HkContrastDown}"/>
                                <TextBlock Grid.Row="4" Text="Gamma +" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="4" Grid.Column="1" x:Name="HkGammaUp" Margin="0,4,8,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                                <Button Grid.Row="4" Grid.Column="2" Content="Clear" Style="{StaticResource GhostButton}" Padding="10,4"
                                        Margin="0,4,0,4" Click="ClearHotkey_Click" Tag="{Binding ElementName=HkGammaUp}"/>
                                <TextBlock Grid.Row="5" Text="Gamma -" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="5" Grid.Column="1" x:Name="HkGammaDown" Margin="0,4,8,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                                <Button Grid.Row="5" Grid.Column="2" Content="Clear" Style="{StaticResource GhostButton}" Padding="10,4"
                                        Margin="0,4,0,4" Click="ClearHotkey_Click" Tag="{Binding ElementName=HkGammaDown}"/>
                                <TextBlock Grid.Row="6" Text="Reset color" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="6" Grid.Column="1" x:Name="HkReset" Margin="0,4,8,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                                <Button Grid.Row="6" Grid.Column="2" Content="Clear" Style="{StaticResource GhostButton}" Padding="10,4"
                                        Margin="0,4,0,4" Click="ClearHotkey_Click" Tag="{Binding ElementName=HkReset}"/>
                            </Grid>

                            <Separator/>
                            <CheckBox x:Name="ChkAutostart" Content="Start with Windows" Margin="0,4"/>
                            <CheckBox x:Name="ChkStartMin" Content="Start minimized to tray" Margin="0,4"/>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="TabLog" Header="Log">
                <DockPanel Margin="0,12,0,0">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Refresh" Style="{StaticResource GhostButton}" Margin="0,0,8,0" Click="RefreshLog_Click"/>
                        <Button Content="Open folder" Style="{StaticResource GhostButton}" Click="OpenLogFolder_Click"/>
                    </StackPanel>
                    <TextBox x:Name="TxtLog" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden"
                             FontFamily="Consolas" FontSize="12" Background="{DynamicResource FieldBrush}"
                             Foreground="{DynamicResource TextBrush}"/>
                </DockPanel>
            </TabItem>
        </TabControl>
        </Grid>

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <TextBlock DockPanel.Dock="Right" Text="made by Nakidev"
                       Foreground="{DynamicResource AccentBrush}" FontSize="11" Opacity="0.85"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="FooterText" Foreground="{DynamicResource MutedBrush}" FontSize="11"
                       Text="Config: %AppData%\DisplayProfileManager\profiles.json" VerticalAlignment="Center"/>
        </DockPanel>
        </Grid><!-- content -->

        <!-- Non-modal toast (Save / Apply) -->
        <Border x:Name="ToastHost" Grid.Row="0" Grid.RowSpan="3"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,36" Padding="22,11"
                Background="{DynamicResource ToastBgBrush}" BorderBrush="{DynamicResource ToastBorderBrush}" BorderThickness="1"
                CornerRadius="20" Opacity="0" Visibility="Collapsed"
                IsHitTestVisible="False" Panel.ZIndex="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.4" Color="#000000"/>
            </Border.Effect>
            <TextBlock x:Name="ToastText" Text="Saved"
                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
        </Border>

        <local:SaveOverlay x:Name="SaveBusy" Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="25"/>
        <local:ScanOverlay x:Name="ScanBusy" Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="30"/>
