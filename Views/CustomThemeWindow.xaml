<Window x:Class="DisplayProfileManager.CustomThemeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Custom theme" Height="640" Width="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        MinHeight="480" MinWidth="480"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="5" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource BgBrush}">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel>
                <TextBlock x:Name="TxtTitle" Text="Custom palette" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button Style="{StaticResource CaptionCloseButton}" HorizontalAlignment="Right" Width="36" Height="28"
                        Click="Cancel_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Width="9" Height="9" Stretch="Uniform" Stroke="{DynamicResource MutedBrush}" StrokeThickness="1.2"
                          Data="M1,1 L9,9 M9,1 L1,9"/>
                </Button>
            </DockPanel>

            <ScrollViewer Grid.Row="1" Margin="0,12,0,10" VerticalScrollBarVisibility="Hidden">
                <StackPanel x:Name="PaletteHost"/>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{DynamicResource PanelBrush}" CornerRadius="10" Padding="14" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock x:Name="LblPreview" Text="Preview" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Accent" Style="{StaticResource AccentButton}" Margin="0,0,8,0"/>
                        <Button Content="Ghost" Style="{StaticResource GhostButton}" Margin="0,0,12,0"/>
                        <CheckBox Content="Checkbox" IsChecked="True" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Muted sample text" Foreground="{DynamicResource MutedBrush}" Margin="0,10,0,0"/>
                    <TextBox Text="Field sample" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <DockPanel Grid.Row="3">
                <Button x:Name="BtnReset" Content="Reset defaults" Style="{StaticResource GhostButton}" Click="Reset_Click"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnCancel" Content="Cancel" Style="{StaticResource GhostButton}" Margin="0,0,8,0" Click="Cancel_Click"/>
                    <Button x:Name="BtnOk" Content="OK" Style="{StaticResource AccentButton}" MinWidth="100" Click="Ok_Click"/>
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>
