<Window x:Class="DisplayProfileManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:DisplayProfileManager"
        Title="Display Profile Manager"
        Height="740" Width="1080"
        MinHeight="580" MinWidth="880"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="ChromeRoot" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
            Background="{DynamicResource BgBrush}" Opacity="0">
    <Grid Background="{DynamicResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Grid Grid.Row="0" Background="{DynamicResource TitleBarBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock x:Name="TitleAppName" Text="Display Profile Manager" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="Monitoring" Margin="12,0,0,0" FontSize="11"
                           Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                <Border x:Name="ActivePill" Margin="12,0,0,0" Padding="10,3" CornerRadius="10"
                        Background="{DynamicResource PillBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="ActiveHeaderText" Text="No game active" FontSize="11"
                               Foreground="{DynamicResource AccentHoverBrush}"/>
                </Border>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Stretch">
                <Button x:Name="BtnSettingsCaption" Style="{StaticResource CaptionButton}" Click="Settings_Click"
                        MinWidth="72" Width="Auto" Padding="10,0"
                        ToolTip="Settings" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock x:Name="TxtSettingsCaption" Text="Settings" FontSize="11"
                               Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                </Button>
                <Button Style="{StaticResource CaptionButton}" Click="Minimize_Click"
                        ToolTip="Minimize"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Width="8" Height="8" Stretch="Uniform" Stroke="{DynamicResource MutedBrush}" StrokeThickness="1"
                          Data="M0,4 L8,4"/>
                </Button>
                <Button Style="{StaticResource CaptionButton}" Click="Maximize_Click"
                        ToolTip="Maximize"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Width="8" Height="8" Stretch="Uniform" Stroke="{DynamicResource MutedBrush}" StrokeThickness="1"
                          Data="M0.5,0.5 H7.5 V7.5 H0.5 Z" Fill="Transparent"/>
                </Button>
                <Button Style="{StaticResource CaptionCloseButton}" Click="Close_Click"
                        ToolTip="Close"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Width="8" Height="8" Stretch="Uniform" Stroke="{DynamicResource MutedBrush}" StrokeThickness="1"
                          Data="M1,1 L7,7 M7,1 L1,7"/>
                </Button>
            </StackPanel>
        </Grid>

        <Grid x:Name="ContentRoot" Grid.Row="1" Margin="18,10,18,14" Background="{DynamicResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnApply" Content="Apply" Style="{StaticResource AccentButton}" Margin="0,0,8,0" Click="Apply_Click"/>
                <local:InfoHint x:Name="InfoApply" Margin="0,0,10,0"/>
                <Button x:Name="BtnEmergency" Content="Emergency Restore" Style="{StaticResource GhostButton}" Click="EmergencyRestore_Click"
                        ToolTip="Restores display, color, power, and session settings to a safe state."/>
                <local:InfoHint x:Name="InfoEmergency" Margin="8,0,0,0"/>
            </StackPanel>
        </DockPanel>

        <local:TabBuddy x:Name="TabMascot" Grid.Row="1" Margin="0,0,0,6" Panel.ZIndex="50"/>
        <Grid Grid.Row="2">
            <TabControl x:Name="MainTabs">
            <TabItem x:Name="TabProfiles" Header="Profiles">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="270"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{DynamicResource PanelBrush}" CornerRadius="10" Padding="10">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                                <TextBox x:Name="TxtSearch" Margin="0,0,0,6" Height="28" FontSize="12"
                                         Padding="8,4" VerticalContentAlignment="Center"
                                         TextChanged="Search_Changed" ToolTip="Search games…"/>
                                <UniformGrid Columns="2" Margin="0,0,0,4">
                                    <Button x:Name="BtnScan" Content="Scan" Style="{StaticResource CompactAccentButton}"
                                            Margin="0,0,3,0" Click="ScanGames_Click"
                                            ToolTip="Find installed and running known games"/>
                                    <Button x:Name="BtnAddManual" Content="Add" Style="{StaticResource CompactGhostButton}"
                                            Margin="3,0,0,0" Click="AddProfile_Click"
                                            ToolTip="Add a game profile manually"/>
                                </UniformGrid>
                                <Button x:Name="BtnRestore" Content="Restore games" Style="{StaticResource CompactGhostButton}"
                                        HorizontalAlignment="Stretch" Click="RestoreCoreGames_Click"
                                        ToolTip="Add Valorant / PUBG / War Thunder / Tarkov if missing"/>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button x:Name="BtnDup" Content="Dup" Style="{StaticResource CompactGhostButton}" Margin="0,0,6,0"
                                            MinWidth="48" HorizontalAlignment="Left" Click="DupProfile_Click"/>
                                    <Button x:Name="BtnDelete" Content="Delete" Style="{StaticResource CompactGhostButton}"
                                            MinWidth="56" HorizontalAlignment="Left" Click="DeleteProfile_Click"/>
                                </StackPanel>
                                <UniformGrid Columns="2">
                                    <Button x:Name="BtnExportProfile" Content="Export" Style="{StaticResource CompactGhostButton}"
                                            Margin="0,0,3,0" Click="ExportProfile_Click"
                                            ToolTip="Export this profile as a shareable pack"/>
                                    <Button x:Name="BtnImportProfile" Content="Import" Style="{StaticResource CompactGhostButton}"
                                            Margin="3,0,0,0" Click="ImportProfile_Click"
                                            ToolTip="Import a profile pack"/>
                                </UniformGrid>
                            </StackPanel>
                            <ListBox x:Name="ProfileList" SelectionChanged="ProfileList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8" Padding="8,7" Background="{Binding TileBrush}" MinHeight="48">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="36"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="32" Height="32" CornerRadius="7" Background="#66000000"
                                                        VerticalAlignment="Center">
                                                    <Grid>
                                                        <Image Source="{Binding Icon}" Width="28" Height="28"
                                                               Stretch="Uniform"
                                                               Visibility="{Binding Icon, Converter={StaticResource NullToVis}}"/>
                                                        <TextBlock Text="{Binding Glyph}" FontWeight="Bold" FontSize="12"
                                                                   Foreground="#F8EAF0" HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="{Binding Icon, Converter={StaticResource InvNullToVis}}"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#FFF8F4"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding ProcessName}" Foreground="#E8D0D8" FontSize="10"
                                                               Opacity="0.85" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False" PanningMode="VerticalOnly">
                        <Border Background="{DynamicResource PanelBrush}" CornerRadius="10" Padding="16">
                            <StackPanel x:Name="EditorPanel">
                                <TextBlock Text="Profile" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <CheckBox x:Name="ChkEnabled" Content="Enabled" Checked="EditorChanged" Unchecked="EditorChanged"/>

                                <TextBlock Text="Name" Margin="0,10,0,4" Foreground="{DynamicResource MutedBrush}"/>
                                <TextBox x:Name="TxtName" TextChanged="EditorChanged"/>

                                <TextBlock Text="Process (.exe)" Margin="0,10,0,4" Foreground="{DynamicResource MutedBrush}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtProcess" Grid.Column="0" TextChanged="EditorChanged"/>
                                    <Button Grid.Column="1" Content="Browse" Style="{StaticResource CompactGhostButton}"
                                            Margin="6,0,0,0" MinWidth="64" HorizontalAlignment="Left" Click="BrowseExe_Click"/>
                                    <Button Grid.Column="2" Content="Running" Style="{StaticResource CompactGhostButton}"
                                            Margin="6,0,0,0" MinWidth="72" HorizontalAlignment="Left" Click="PickRunning_Click"
                                            ToolTip="Pick a process that is already running"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button x:Name="BtnLaunchGame" Content="Launch game" Style="{StaticResource CompactAccentButton}"
                                            Margin="0,0,8,0" MinWidth="120"
                                            Click="LaunchGame_Click"
                                            ToolTip="Start this game's exe (set path via Browse or Scan)"/>
                                    <Button x:Name="BtnOverlay" Content="Live overlay" Style="{StaticResource CompactGhostButton}"
                                            Click="Overlay_Click"
                                            ToolTip="Floating panel over the game — tune presets live"/>
                                </StackPanel>

                                <Separator/>
                                <TextBlock Text="Display" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <DockPanel Margin="0,0,0,0">
                                    <local:InfoHint x:Name="InfoRes" DockPanel.Dock="Right"/>
                                    <CheckBox x:Name="ChkApplyRes" Content="Change resolution" VerticalAlignment="Center"
                                              Checked="EditorChanged" Unchecked="EditorChanged"/>
                                </DockPanel>
                                <ComboBox x:Name="CmbResolution" Margin="0,6,0,0" IsEditable="True"
                                          SelectionChanged="Resolution_Changed" LostFocus="Resolution_LostFocus"/>
                                <TextBlock x:Name="LblRefreshRate" Text="Refresh rate" Margin="0,10,0,4" Foreground="{DynamicResource MutedBrush}"/>
                                <ComboBox x:Name="CmbRefreshRate" SelectionChanged="EditorChanged">
                                    <ComboBoxItem Content="(don't change)" Tag="0" IsSelected="True"/>
                                </ComboBox>
                                <TextBlock x:Name="LblDisplay" Text="Monitor" Margin="0,10,0,4" Foreground="{DynamicResource MutedBrush}"/>
                                <ComboBox x:Name="CmbDisplay" SelectionChanged="EditorChanged"/>
                                <DockPanel Margin="0,12,0,0">
                                    <local:InfoHint x:Name="InfoPower" DockPanel.Dock="Right"/>
                                    <CheckBox x:Name="ChkApplyPower" Content="Change power plan" VerticalAlignment="Center"
                                              Checked="EditorChanged" Unchecked="EditorChanged"/>
                                </DockPanel>
                                <ComboBox x:Name="CmbPower" Margin="0,6,0,0" SelectionChanged="EditorChanged">
                                    <ComboBoxItem Content="highPerformance" Tag="highPerformance"/>
                                    <ComboBoxItem Content="balanced" Tag="balanced"/>
                                    <ComboBoxItem Content="(don't change)" Tag=""/>
                                </ComboBox>
                                <TextBlock x:Name="LblStartupPreset" Text="Startup preset" Margin="0,12,0,4" Foreground="{DynamicResource MutedBrush}"/>
                                <ComboBox x:Name="CmbStartupPreset" SelectionChanged="EditorChanged">
                                    <ComboBoxItem Content="(none)" Tag="" IsSelected="True"/>
                                </ComboBox>
                                <TextBlock x:Name="LblAliases" Text="Process aliases (comma-separated)" Margin="0,10,0,4" Foreground="{DynamicResource MutedBrush}"/>
                                <TextBox x:Name="TxtAliases" TextChanged="EditorChanged"
                                         ToolTip="Extra .exe names that also activate this profile"/>
                                <TextBlock x:Name="LblApplyDelay" Text="Apply delay: 0 s" Margin="0,10,0,4" Foreground="{DynamicResource MutedBrush}"/>
                                <Slider x:Name="SldApplyDelay" Minimum="0" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="ColorSlider_ValueChanged"/>
                                <CheckBox x:Name="ChkApplyOnFocus" Content="Wait for game window focus" Margin="0,8,0,0"
                                          Checked="EditorChanged" Unchecked="EditorChanged"/>
                                <DockPanel Margin="0,12,0,4">
                                    <local:InfoHint x:Name="InfoRestoreMode" DockPanel.Dock="Right"/>
                                    <TextBlock x:Name="LblRestoreMode" Text="On game exit" Foreground="{DynamicResource MutedBrush}"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                                <ComboBox x:Name="CmbRestoreMode" SelectionChanged="EditorChanged">
                                    <ComboBoxItem Content="Restore previous snapshot" Tag="PreviousSnapshot" IsSelected="True"/>
                                    <ComboBoxItem Content="Restore Global Defaults" Tag="GlobalDefaults"/>
                                    <ComboBoxItem Content="Do nothing" Tag="DoNothing"/>
                                </ComboBox>

                                <Separator/>
                                <DockPanel Margin="0,0,0,6">
                                    <local:InfoHint x:Name="InfoSession" DockPanel.Dock="Right"/>
                                    <TextBlock x:Name="LblSessionTitle" Text="Session extras" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </DockPanel>
                                <TextBlock x:Name="LblSessionSub" Text="System-only tweaks (no game injection)" FontSize="11" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="LblSessionTemplates" Text="Templates" FontSize="11" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,4"/>
                                <UniformGrid Columns="3" Margin="0,0,0,8">
                                    <Button x:Name="BtnTplCompetitive" Content="Competitive" Style="{StaticResource CompactGhostButton}"
                                            Margin="0,0,4,0" Click="SessionTemplateCompetitive_Click"/>
                                    <Button x:Name="BtnTplImmersive" Content="Immersive" Style="{StaticResource CompactGhostButton}"
                                            Margin="2,0,2,0" Click="SessionTemplateImmersive_Click"/>
                                    <Button x:Name="BtnTplMinimal" Content="Minimal" Style="{StaticResource CompactGhostButton}"
                                            Margin="4,0,0,0" Click="SessionTemplateMinimal_Click"/>
                                </UniformGrid>
                                <TextBlock x:Name="LblMonitorLayout" Text="Monitor layout" Margin="0,0,0,4" Foreground="{DynamicResource MutedBrush}"/>
                                <ComboBox x:Name="CmbMonitorLayout" Margin="0,0,0,8" SelectionChanged="MonitorLayout_Changed">
                                    <ComboBoxItem Content="Keep all monitors" Tag="keepAll" IsSelected="True"/>
                                    <ComboBoxItem Content="Isolate primary" Tag="isolatePrimary"/>
                                    <ComboBoxItem Content="Primary only" Tag="primaryOnly"/>
                                </ComboBox>
                                <DockPanel>
                                    <local:InfoHint x:Name="InfoDeferred" DockPanel.Dock="Right"/>
                                    <TextBlock x:Name="LblDeferred" Text="Deferred re-apply: 0 s" Foreground="{DynamicResource MutedBrush}"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                                <Slider x:Name="SldDeferred" Minimum="0" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="ColorSlider_ValueChanged"/>
                                <DockPanel Margin="0,8,0,0">
                                    <local:InfoHint x:Name="InfoQuiet" DockPanel.Dock="Right"/>
                                    <CheckBox x:Name="ChkQuietToast" Content="Quiet notifications" VerticalAlignment="Center"
                                              Checked="EditorChanged" Unchecked="EditorChanged"/>
                                </DockPanel>
                                <DockPanel Margin="0,4,0,0">
                                    <local:InfoHint x:Name="InfoNight" DockPanel.Dock="Right"/>
                                    <CheckBox x:Name="ChkNoNightLight" Content="Disable Night Light" VerticalAlignment="Center"
                                              Checked="EditorChanged" Unchecked="EditorChanged"/>
                                </DockPanel>
                                <DockPanel Margin="0,4,0,0">
                                    <local:InfoHint x:Name="InfoHdr" DockPanel.Dock="Right"/>
                                    <CheckBox x:Name="ChkNoAutoHdr" Content="Disable Auto HDR" VerticalAlignment="Center"
                                              Checked="EditorChanged" Unchecked="EditorChanged"/>
                                </DockPanel>
                                <DockPanel Margin="0,4,0,0">
                                    <local:InfoHint x:Name="InfoPrimary" DockPanel.Dock="Right"/>
                                    <CheckBox x:Name="ChkIsolateMon" Content="Primary monitor only" VerticalAlignment="Center"
                                              Checked="EditorChanged" Unchecked="EditorChanged"/>
                                </DockPanel>
                                <DockPanel Margin="0,4,0,0">
                                    <local:InfoHint x:Name="InfoMonBright" DockPanel.Dock="Right"/>
                                    <CheckBox x:Name="ChkMonBright" Content="Set monitor brightness (DDC/CI)" VerticalAlignment="Center"
                                              Checked="EditorChanged" Unchecked="EditorChanged"/>
                                </DockPanel>
                                <TextBlock x:Name="LblMonBright" Text="Brightness: 80%" Margin="0,6,0,0" Foreground="{DynamicResource MutedBrush}"/>
                                <Slider x:Name="SldMonBright" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="ColorSlider_ValueChanged"/>
                                <DockPanel Margin="0,8,0,0">
                                    <local:InfoHint x:Name="InfoAudio" DockPanel.Dock="Right"/>
                                    <CheckBox x:Name="ChkSwitchAudio" Content="Switch default audio device" VerticalAlignment="Center"
                                              Checked="EditorChanged" Unchecked="EditorChanged"/>
                                </DockPanel>
                                <ComboBox x:Name="CmbAudio" Margin="0,6,0,0" SelectionChanged="EditorChanged"/>
                                <DockPanel Margin="0,8,0,4">
                                    <local:InfoHint x:Name="InfoScaling" DockPanel.Dock="Right"/>
                                    <TextBlock x:Name="LblScaling" Text="Scaling mode" Foreground="{DynamicResource MutedBrush}"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                                <ComboBox x:Name="CmbScaling" SelectionChanged="EditorChanged">
                                    <ComboBoxItem Content="default" Tag="default" IsSelected="True"/>
                                    <ComboBoxItem Content="stretch" Tag="stretch"/>
                                    <ComboBoxItem Content="center" Tag="center"/>
                                </ComboBox>

                                <Separator/>
                                <DockPanel Margin="0,0,0,8">
                                    <local:InfoHint x:Name="InfoCompanions" DockPanel.Dock="Right"/>
                                    <Button DockPanel.Dock="Right" Content="Add" Style="{StaticResource CompactGhostButton}"
                                            MinWidth="56" Margin="0,0,4,0" HorizontalAlignment="Right" Click="AddCompanion_Click"/>
                                    <TextBlock Text="Companions" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </DockPanel>
                                <ListBox x:Name="CompanionList" Height="100" DisplayMemberPath="ListLabel"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="Edit" Style="{StaticResource CompactGhostButton}" Margin="0,0,6,0"
                                            MinWidth="56" HorizontalAlignment="Left" Click="EditCompanion_Click"/>
                                    <Button Content="Remove" Style="{StaticResource CompactGhostButton}"
                                            MinWidth="64" HorizontalAlignment="Left" Click="RemoveCompanion_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem x:Name="TabPresets" Header="Presets">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Game picker -->
                    <Border Grid.Column="0" Background="{DynamicResource PanelBrush}" CornerRadius="10" Padding="10">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Game" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ListBox x:Name="PresetGameList" SelectionChanged="PresetGameList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8" Padding="8,7" Background="{Binding TileBrush}" MinHeight="44">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="32"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="28" Height="28" CornerRadius="6" Background="#66000000">
                                                    <Grid>
                                                        <Image Source="{Binding Icon}" Width="24" Height="24"
                                                               Visibility="{Binding Icon, Converter={StaticResource NullToVis}}"/>
                                                        <TextBlock Text="{Binding Glyph}" FontWeight="Bold" FontSize="11"
                                                                   Foreground="#FFF8F4" HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="{Binding Icon, Converter={StaticResource InvNullToVis}}"/>
                                                    </Grid>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold"
                                                           Foreground="#FFF8F4" VerticalAlignment="Center" Margin="8,0,0,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2" Background="{DynamicResource PanelBrush}" CornerRadius="10" Padding="10">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" x:Name="LblPresetGame" Text="Presets"
                                       FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                <UniformGrid Columns="2" Rows="2" Margin="0,0,0,6">
                                    <Button x:Name="BtnPresetAdd" Content="Add" Style="{StaticResource CompactAccentButton}"
                                            Margin="0,0,4,4" Click="AddPreset_Click"/>
                                    <Button x:Name="BtnPresetDelete" Content="Delete" Style="{StaticResource CompactGhostButton}"
                                            Margin="4,0,0,4" Click="DeletePreset_Click"/>
                                    <Button x:Name="BtnPresetExport" Content="Export" Style="{StaticResource CompactGhostButton}"
                                            Margin="0,4,4,0" Click="ExportPresets_Click"/>
                                    <Button x:Name="BtnPresetImport" Content="Import" Style="{StaticResource CompactGhostButton}"
                                            Margin="4,4,0,0" Click="ImportPresets_Click"/>
                                </UniformGrid>
                                <Button x:Name="BtnPackGallery" Content="Pack gallery" Style="{StaticResource CompactGhostButton}"
                                        HorizontalAlignment="Stretch" Margin="0,0,0,6" Click="PackGallery_Click"
                                        ToolTip="Browse built-in preset packs"/>
                                <Button x:Name="BtnLaunchGamePreset" Content="Launch game" Style="{StaticResource CompactAccentButton}"
                                        HorizontalAlignment="Stretch" Click="LaunchGame_Click"
                                        ToolTip="Start the selected game's exe"/>
                            </StackPanel>
                            <ListBox x:Name="PresetList" SelectionChanged="PresetList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,2">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <TextBlock FontSize="11" Foreground="{DynamicResource MutedBrush}">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0}  ·  {1}">
                                                        <Binding Path="Summary"/>
                                                        <Binding Path="Hotkey" TargetNullValue="no hotkey"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <ScrollViewer Grid.Column="4" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False" PanningMode="VerticalOnly">
                        <Border Background="{DynamicResource PanelBrush}" CornerRadius="10" Padding="16">
                            <StackPanel x:Name="PresetEditor">
                                <TextBlock Text="Preset for this game" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock Text="Press any key (NumPad, 1–9, letters, F-keys). Optional Ctrl/Alt/Shift. Bound to this game — works in-game via keyboard hook."
                                           Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,12" FontSize="11"/>

                                <TextBlock Text="Name" Foreground="{DynamicResource MutedBrush}"/>
                                <TextBox x:Name="TxtPresetName" Margin="0,4,0,10"
                                         TextChanged="PresetName_TextChanged" LostFocus="PresetName_LostFocus"/>

                                <TextBlock Text="Hotkey (click &amp; press)" Foreground="{DynamicResource MutedBrush}"/>
                                <TextBox x:Name="TxtPresetHotkey" Margin="0,4,0,10" PreviewKeyDown="HotkeyBox_PreviewKeyDown" TextChanged="PresetEditorChanged"/>
                                <CheckBox x:Name="ChkPresetRes" Content="Set resolution" Checked="PresetEditorChanged" Unchecked="PresetEditorChanged"/>
                                <ComboBox x:Name="CmbPresetRes" Margin="0,6,0,12" SelectionChanged="PresetEditorChanged"/>

                                <TextBlock Text="Color" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Applied when this preset is selected (hotkey or overlay)."
                                           Foreground="{DynamicResource MutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <DockPanel Margin="0,0,0,4">
                                    <local:InfoHint x:Name="InfoPresetBackend" DockPanel.Dock="Right"/>
                                    <TextBlock Text="Backend" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                                </DockPanel>
                                <ToggleButton x:Name="TogPresetBackend" Style="{StaticResource BackendSlideToggle}"
                                              Content="NVIDIA" Checked="PresetBackendToggle_Changed" Unchecked="PresetBackendToggle_Changed"/>
                                <TextBlock x:Name="LblPresetBackendActive" Text="Active: NVIDIA"
                                           FontSize="12" FontWeight="SemiBold" Margin="0,8,0,8"
                                           Foreground="{DynamicResource AccentBrush}"/>
                                <DockPanel Margin="0,8,0,0">
                                    <local:InfoHint x:Name="InfoPresetLock" DockPanel.Dock="Right"/>
                                    <CheckBox x:Name="ChkPresetLock" Content="Lock while game running" VerticalAlignment="Center"
                                              Checked="PresetEditorChanged" Unchecked="PresetEditorChanged"/>
                                </DockPanel>
                                <TextBlock x:Name="LblPresetB" Text="Brightness: 0.50" Margin="0,8,0,0" Foreground="{DynamicResource MutedBrush}"/>
                                <Slider x:Name="SldPresetB" Minimum="0" Maximum="1" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="PresetColor_ValueChanged"/>
                                <TextBlock x:Name="LblPresetC" Text="Contrast: 1.00" Margin="0,6,0,0" Foreground="{DynamicResource MutedBrush}"/>
                                <Slider x:Name="SldPresetC" Minimum="0" Maximum="2" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="PresetColor_ValueChanged"/>
                                <TextBlock x:Name="LblPresetG" Text="Gamma: 1.00" Margin="0,6,0,0" Foreground="{DynamicResource MutedBrush}"/>
                                <Slider x:Name="SldPresetG" Minimum="0.5" Maximum="6" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="PresetColor_ValueChanged"/>
                                <TextBlock x:Name="LblPresetV" Text="Vibrance: 50" Margin="0,6,0,0" Foreground="{DynamicResource MutedBrush}"/>
                                <Slider x:Name="SldPresetV" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="PresetColor_ValueChanged"/>
                                <TextBlock x:Name="LblPresetShadow" Text="Shadow Boost: 0" Margin="0,6,0,0" Foreground="{DynamicResource MutedBrush}"/>
                                <Slider x:Name="SldPresetShadow" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="PresetColor_ValueChanged"/>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem x:Name="TabGlobal" Header="Global">
                <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False" PanningMode="VerticalOnly">
                    <Border Background="{DynamicResource PanelBrush}" CornerRadius="10" Padding="16">
                        <StackPanel MaxWidth="620" HorizontalAlignment="Left">
                            <TextBlock Text="Defaults (no game running)" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <TextBlock Text="Default resolution" Foreground="{DynamicResource MutedBrush}"/>
                            <ComboBox x:Name="CmbDefaultRes" Margin="0,4,0,12" SelectionChanged="GlobalEditorChanged"/>
                            <TextBlock Text="Default power plan" Foreground="{DynamicResource MutedBrush}"/>
                            <ComboBox x:Name="CmbDefaultPower" Margin="0,4,0,12" SelectionChanged="GlobalEditorChanged">
                                <ComboBoxItem Content="balanced" IsSelected="True"/>
                                <ComboBoxItem Content="highPerformance"/>
                            </ComboBox>
                            <TextBlock Text="Color / gamma is configured per-game on the Presets tab only."
                                       Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>

                            <Separator/>
                            <TextBlock x:Name="LblAppHotkeys" Text="App hotkeys" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="LblAppHotkeysHint" Text="Click a field and press a key (modifiers optional). Esc / Backspace / Delete or Clear removes it. Per-preset binds are on the Presets tab."
                                       Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="LblHkOverlay" Grid.Row="0" Text="Toggle overlay" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="HkToggleOverlay" Margin="0,4,8,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                                <Button Grid.Row="0" Grid.Column="2" Content="Clear" Style="{StaticResource CompactGhostButton}" Padding="10,4"
                                        Margin="0,4,0,4" MinWidth="48" HorizontalAlignment="Left" Click="ClearHotkey_Click" Tag="{Binding ElementName=HkToggleOverlay}"/>
                                <TextBlock x:Name="LblHkEmergency" Grid.Row="1" Text="Emergency Restore" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="HkEmergency" Margin="0,4,8,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                                <Button Grid.Row="1" Grid.Column="2" Content="Clear" Style="{StaticResource CompactGhostButton}" Padding="10,4"
                                        Margin="0,4,0,4" MinWidth="48" HorizontalAlignment="Left" Click="ClearHotkey_Click" Tag="{Binding ElementName=HkEmergency}"/>
                                <TextBlock x:Name="LblHkNext" Grid.Row="2" Text="Next preset" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="HkNextPreset" Margin="0,4,8,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                                <Button Grid.Row="2" Grid.Column="2" Content="Clear" Style="{StaticResource CompactGhostButton}" Padding="10,4"
                                        Margin="0,4,0,4" MinWidth="48" HorizontalAlignment="Left" Click="ClearHotkey_Click" Tag="{Binding ElementName=HkNextPreset}"/>
                                <TextBlock x:Name="LblHkPrev" Grid.Row="3" Text="Previous preset" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="1" x:Name="HkPrevPreset" Margin="0,4,8,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                                <Button Grid.Row="3" Grid.Column="2" Content="Clear" Style="{StaticResource CompactGhostButton}" Padding="10,4"
                                        Margin="0,4,0,4" MinWidth="48" HorizontalAlignment="Left" Click="ClearHotkey_Click" Tag="{Binding ElementName=HkPrevPreset}"/>
                                <TextBlock x:Name="LblHkAb" Grid.Row="4" Text="A/B compare" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="4" Grid.Column="1" x:Name="HkCompareAb" Margin="0,4,8,4" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                                <Button Grid.Row="4" Grid.Column="2" Content="Clear" Style="{StaticResource CompactGhostButton}" Padding="10,4"
                                        Margin="0,4,0,4" MinWidth="48" HorizontalAlignment="Left" Click="ClearHotkey_Click" Tag="{Binding ElementName=HkCompareAb}"/>
                            </Grid>

                            <Separator/>
                            <DockPanel Margin="0,4,0,0">
                                <local:InfoHint x:Name="InfoAutostart" DockPanel.Dock="Right"/>
                                <CheckBox x:Name="ChkAutostart" Content="Start with Windows" VerticalAlignment="Center"
                                          Checked="GlobalEditorChanged" Unchecked="GlobalEditorChanged"/>
                            </DockPanel>
                            <DockPanel Margin="0,4,0,0">
                                <local:InfoHint x:Name="InfoStartMin" DockPanel.Dock="Right"/>
                                <CheckBox x:Name="ChkStartMin" Content="Start minimized to tray" VerticalAlignment="Center"
                                          Checked="GlobalEditorChanged" Unchecked="GlobalEditorChanged"/>
                            </DockPanel>
                            <Separator Margin="0,12,0,8"/>
                            <TextBlock x:Name="LblResetGlobalHint" Text="Reset Global defaults to factory (resolution / power)."
                                       Foreground="{DynamicResource MutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <Button x:Name="BtnReset" Content="Reset Global defaults" Style="{StaticResource GhostButton}"
                                    HorizontalAlignment="Left" Click="ResetSettings_Click"
                                    ToolTip="Rewrite Global defaults to factory and restore the display."/>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="TabLog" Header="Log">
                <DockPanel Margin="0,12,0,0">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Refresh" Style="{StaticResource GhostButton}" Margin="0,0,8,0" Click="RefreshLog_Click"/>
                        <Button Content="Open folder" Style="{StaticResource GhostButton}" Click="OpenLogFolder_Click"/>
                    </StackPanel>
                    <TextBox x:Name="TxtLog" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden"
                             FontFamily="Consolas" FontSize="12" Background="{DynamicResource FieldBrush}"
                             Foreground="{DynamicResource TextBrush}"/>
                </DockPanel>
            </TabItem>
        </TabControl>
        </Grid>

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <TextBlock DockPanel.Dock="Right" Text="made by Nakidev"
                       Foreground="{DynamicResource AccentBrush}" FontSize="11" Opacity="0.85"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="FooterText" Foreground="{DynamicResource MutedBrush}" FontSize="11"
                       Text="Config: %AppData%\DisplayProfileManager\profiles.json" VerticalAlignment="Center"/>
        </DockPanel>
        </Grid><!-- content -->

        <!-- Non-modal toast (Save / Apply) -->
        <Border x:Name="ToastHost" Grid.Row="0" Grid.RowSpan="3"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,36" Padding="22,11"
                Background="{DynamicResource ToastBgBrush}" BorderBrush="{DynamicResource ToastBorderBrush}" BorderThickness="1"
                CornerRadius="20" Opacity="0" Visibility="Collapsed"
                IsHitTestVisible="False" Panel.ZIndex="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.4" Color="#000000"/>
            </Border.Effect>
            <TextBlock x:Name="ToastText" Text="Saved"
                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
        </Border>

        <local:SaveOverlay x:Name="SaveBusy" Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="25"/>
        <local:ScanOverlay x:Name="ScanBusy" Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="30"/>
        <local:EggOverlay x:Name="EggBusy" Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="40"/>
    </Grid><!-- root -->
    </Border>
</Window>
