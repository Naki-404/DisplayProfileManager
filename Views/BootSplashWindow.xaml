<Window x:Class="DisplayProfileManager.BootSplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Display Profile Manager"
        Width="360" Height="280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        Topmost="True">
    <Window.Resources>
        <Storyboard x:Key="BootStory">
            <DoubleAnimation Storyboard.TargetName="Card" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.28">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX"
                             From="0.9" To="1" Duration="0:0:0.36">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.4"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY"
                             From="0.9" To="1" Duration="0:0:0.36">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.4"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleX"
                             From="0.5" To="1" Duration="0:0:0.4" BeginTime="0:0:0.06">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.55"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleY"
                             From="0.5" To="1" Duration="0:0:0.4" BeginTime="0:0:0.06">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.55"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="SpinRotate" Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:1.1" BeginTime="0:0:0.15" RepeatBehavior="2x"/>

            <DoubleAnimation Storyboard.TargetName="BrandTitle" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.28" BeginTime="0:0:0.22"/>
            <DoubleAnimation Storyboard.TargetName="Subtitle" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.24" BeginTime="0:0:0.34"/>

            <DoubleAnimation Storyboard.TargetName="Card" Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.28" BeginTime="0:0:1.55">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX"
                             From="1" To="0.96" Duration="0:0:0.28" BeginTime="0:0:1.55"/>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY"
                             From="1" To="0.96" Duration="0:0:0.28" BeginTime="0:0:1.55"/>
        </Storyboard>
    </Window.Resources>

    <Border x:Name="Card" CornerRadius="18" Margin="16" Opacity="0" Padding="32,28"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
            Background="{DynamicResource PanelBrush}"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="CardScale" ScaleX="0.9" ScaleY="0.9"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="4" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid Width="64" Height="64" Margin="0,0,0,20" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <ScaleTransform x:Name="IconScale" ScaleX="0.5" ScaleY="0.5"/>
                </Grid.RenderTransform>
                <Ellipse Fill="{DynamicResource FieldBrush}"
                         Stroke="{DynamicResource BorderBrush}" StrokeThickness="1"/>
                <Grid Width="40" Height="40" RenderTransformOrigin="0.5,0.5"
                      HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid.RenderTransform>
                        <RotateTransform x:Name="SpinRotate"/>
                    </Grid.RenderTransform>
                    <Ellipse Width="40" Height="40" Stroke="{DynamicResource TrackBrush}" StrokeThickness="2.5"/>
                    <Path Stroke="{DynamicResource AccentBrush}" StrokeThickness="2.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="M20,2 A18,18 0 1 1 2,20"/>
                </Grid>
                <!-- Monitor glyph -->
                <Path Width="18" Height="14" Stretch="Uniform" Fill="{DynamicResource TextBrush}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M2,2 H16 V11 H2 Z M7,12 H11 V14 H13 V15 H5 V14 H7 Z" Opacity="0.95"/>
            </Grid>

            <TextBlock x:Name="BrandTitle" Text="Display Profile Manager"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center" Opacity="0"/>
            <TextBlock x:Name="Subtitle" Text="Starting…"
                       FontSize="12" Foreground="{DynamicResource MutedBrush}"
                       HorizontalAlignment="Center" Margin="0,6,0,0" Opacity="0"/>
        </StackPanel>
    </Border>
</Window>
