<Window x:Class="DisplayProfileManager.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Settings" Height="640" Width="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource BgBrush}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel>
                <Button Style="{StaticResource CaptionCloseButton}" HorizontalAlignment="Right"
                        Width="36" Height="28" Click="Close_Click"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Width="9" Height="9" Stretch="Uniform" Stroke="{DynamicResource MutedBrush}" StrokeThickness="1.2"
                          Data="M1,1 L9,9 M9,1 L1,9"/>
                </Button>
                <TextBlock x:Name="TxtTitle" Text="Settings" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </DockPanel>

            <ScrollViewer Grid.Row="1" Margin="0,14,0,12" VerticalScrollBarVisibility="Hidden">
                <StackPanel>
                    <TextBlock x:Name="LblAppearance" Text="Appearance" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock x:Name="LblLang" Text="Language" Foreground="{DynamicResource MutedBrush}"/>
                    <ComboBox x:Name="CmbLang" Margin="0,4,0,10" SelectionChanged="Lang_Changed">
                        <ComboBoxItem Content="English" Tag="en"/>
                        <ComboBoxItem Content="Русский" Tag="ru"/>
                    </ComboBox>
                    <TextBlock x:Name="LblTheme" Text="Theme" Foreground="{DynamicResource MutedBrush}"/>
                    <ComboBox x:Name="CmbTheme" Margin="0,4,0,8" SelectionChanged="Theme_Changed">
                        <ComboBoxItem Content="Dark" Tag="dark"/>
                        <ComboBoxItem Content="Light" Tag="light"/>
                        <ComboBoxItem Content="Custom" Tag="custom"/>
                    </ComboBox>
                    <Button x:Name="BtnEditPalette" Content="Edit palette…" Style="{StaticResource GhostButton}"
                            HorizontalAlignment="Left" Margin="0,0,0,12" Click="EditPalette_Click"/>

                    <TextBlock x:Name="LblMonitor" Text="Monitor" Foreground="{DynamicResource MutedBrush}"/>
                    <ComboBox x:Name="CmbMonitor" Margin="0,4,0,12"/>

                    <TextBlock x:Name="LblBehavior" Text="Behavior" FontWeight="SemiBold" Margin="0,8,0,8"/>
                    <CheckBox x:Name="ChkAutostart"/>
                    <CheckBox x:Name="ChkStartMin"/>
                    <CheckBox x:Name="ChkNotify"/>
                    <CheckBox x:Name="ChkBackup"/>
                    <CheckBox x:Name="ChkTrayClose"/>
                    <CheckBox x:Name="ChkConfirmDelete"/>
                    <CheckBox x:Name="ChkShowActive"/>

                    <TextBlock x:Name="LblOverlay" Text="Live overlay" FontWeight="SemiBold" Margin="0,16,0,8"/>
                    <CheckBox x:Name="ChkOverlayAuto" Content="Show overlay when a game starts"/>
                    <CheckBox x:Name="ChkOverlayHotkeyOnly" Content="Hotkey-only overlay (compact pill)" Margin="0,4,0,0"/>
                    <TextBlock x:Name="LblOverlayHint" Text="Compact topmost panel with live color sliders over the game."
                               FontSize="11" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>

                    <TextBlock x:Name="LblSound" Text="Sound" FontWeight="SemiBold" Margin="0,16,0,8"/>
                    <CheckBox x:Name="ChkUiSounds" Content="UI sounds" Checked="UiSound_Changed" Unchecked="UiSound_Changed"/>
                    <DockPanel Margin="0,8,0,0">
                        <TextBlock x:Name="LblSoundVol" Text="Volume" Width="70" VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedBrush}"/>
                        <TextBlock x:Name="LblSoundVolVal" DockPanel.Dock="Right" Width="40" TextAlignment="Right"
                                   VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}" Text="70%"/>
                        <Slider x:Name="SldSoundVol" Minimum="0" Maximum="100" TickFrequency="5"
                                IsSnapToTickEnabled="True" Value="70" Margin="8,0"
                                ValueChanged="SoundVol_Changed"/>
                    </DockPanel>
                    <CheckBox x:Name="ChkMuteInGame" Content="Mute UI sounds while a game is active" Margin="0,8,0,0"
                              Checked="MuteInGame_Changed" Unchecked="MuteInGame_Changed"/>
                    <DockPanel Margin="0,10,0,0">
                        <Button x:Name="BtnPreviewSound" Content="Preview" DockPanel.Dock="Right" Style="{StaticResource CompactGhostButton}"
                                Margin="8,0,0,0" Click="PreviewSound_Click"/>
                        <ComboBox x:Name="CmbSoundPreview" HorizontalAlignment="Stretch">
                            <ComboBoxItem x:Name="ItmSoundOpen" Content="Open" Tag="open"/>
                            <ComboBoxItem x:Name="ItmSoundClick" Content="Click" Tag="click"/>
                            <ComboBoxItem x:Name="ItmSoundSave" Content="Save" Tag="save"/>
                            <ComboBoxItem x:Name="ItmSoundLaunch" Content="Launch" Tag="launch"/>
                            <ComboBoxItem x:Name="ItmSoundDone" Content="Done" Tag="done"/>
                            <ComboBoxItem x:Name="ItmSoundEmpty" Content="Empty" Tag="empty"/>
                            <ComboBoxItem x:Name="ItmSoundArmed" Content="Armed" Tag="armed"/>
                            <ComboBoxItem x:Name="ItmSoundWarn" Content="Warn" Tag="warn"/>
                            <ComboBoxItem x:Name="ItmSoundError" Content="Error" Tag="error"/>
                            <ComboBoxItem x:Name="ItmSoundPreset" Content="Preset applied" Tag="preset"/>
                        </ComboBox>
                    </DockPanel>

                    <TextBlock x:Name="LblData" Text="Data" FontWeight="SemiBold" Margin="0,16,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnExport" Content="Export…" Style="{StaticResource GhostButton}" Margin="0,0,8,0" Click="Export_Click"/>
                        <Button x:Name="BtnImport" Content="Import…" Style="{StaticResource GhostButton}" Click="Import_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="LblConfigPath" Text="" IsHitTestVisible="False"
                               Foreground="{DynamicResource MutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0"/>

                    <TextBlock x:Name="LblAbout" Text="About" FontWeight="SemiBold" Margin="0,20,0,8"/>
                    <TextBlock x:Name="LblAboutCreator" Text="Created by Nakidev"
                               Foreground="{DynamicResource TextBrush}" FontSize="13"/>
                    <TextBlock x:Name="LblAboutContacts" Text="Discord &amp; Telegram: @nakidev"
                               Foreground="{DynamicResource AccentBrush}" FontSize="12" Margin="0,4,0,0"
                               Cursor="Hand" MouseLeftButtonUp="AboutContacts_Click"
                               ToolTip="Open https://t.me/nakidev"/>
                    <TextBlock x:Name="LblAboutSite" Text="github.com/Naki-404/DisplayProfileManager"
                               Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,6,0,0"
                               Cursor="Hand" MouseLeftButtonUp="AboutSite_Click"
                               TextDecorations="Underline"/>
                </StackPanel>
            </ScrollViewer>

            <DockPanel Grid.Row="2">
                <Button x:Name="BtnCancel" Content="Cancel" Style="{StaticResource GhostButton}" Click="Close_Click"/>
                <Button x:Name="BtnSave" Content="Save" Style="{StaticResource AccentButton}"
                        HorizontalAlignment="Right" MinWidth="100" Click="Save_Click"/>
            </DockPanel>
        </Grid>
    </Border>
</Window>
