<Window x:Class="DisplayProfileManager.ProcessPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Running processes" Height="480" Width="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBox x:Name="TxtFilter" Margin="0,0,0,8" TextChanged="TxtFilter_TextChanged"/>
        <ListBox Grid.Row="1" x:Name="ProcList" MouseDoubleClick="ProcList_MouseDoubleClick"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Cancel" Style="{StaticResource GhostButton}" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Select" Style="{StaticResource AccentButton}" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
