<Window x:Class="DisplayProfileManager.ThemedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        MinWidth="300"
        MaxWidth="420"
        Opacity="0"
        Loaded="Window_Loaded">
    <Border x:Name="Card" Margin="12" CornerRadius="10"
            Background="#1A1418" BorderBrush="#3D2A34" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.45" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#160F13" CornerRadius="10,10,0,0" Padding="14,10">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Style="{StaticResource CaptionCloseButton}"
                            Width="28" Height="28" Click="Close_Click" Margin="8,0,0,0">
                        <Path Width="8" Height="8" Stretch="Uniform"
                              Stroke="#B08A9A" StrokeThickness="1.2"
                              Data="M1,1 L9,9 M9,1 L1,9"/>
                    </Button>
                    <TextBlock x:Name="TitleText" Text="Display Profile Manager"
                               Foreground="#F3E6EC" FontWeight="SemiBold" FontSize="13"
                               VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <TextBlock Grid.Row="1" x:Name="MessageText" Text="Saved."
                       Margin="18,16" Foreground="#F3E6EC" FontSize="13"
                       TextWrapping="Wrap"/>

            <Border Grid.Row="2" Background="#140F12" CornerRadius="0,0,10,10" Padding="14,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnCancel" Content="Cancel" Style="{StaticResource GhostButton}"
                            MinWidth="80" Margin="0,0,8,0" Visibility="Collapsed" Click="Cancel_Click"/>
                    <Button x:Name="BtnOk" Content="OK" Style="{StaticResource AccentButton}"
                            MinWidth="80" IsDefault="True" Click="Ok_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
