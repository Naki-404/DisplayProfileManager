<Window x:Class="DisplayProfileManager.Setup.UninstallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uninstall Display Profile Manager"
        Width="460" Height="340"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI" FontSize="13"
        Loaded="Window_Loaded">
  <Border x:Name="Chrome" CornerRadius="14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
          Background="{StaticResource BgBrush}" Opacity="0" RenderTransformOrigin="0.5,0.5">
    <Border.RenderTransform>
      <ScaleTransform x:Name="ChromeScale" ScaleX="0.96" ScaleY="0.96"/>
    </Border.RenderTransform>
    <Border.Effect>
      <DropShadowEffect BlurRadius="28" ShadowDepth="4" Opacity="0.55" Color="#000000"/>
    </Border.Effect>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="44"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Background="{StaticResource TitleBarBrush}" CornerRadius="14,14,0,0"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <DockPanel Margin="14,0,6,0">
          <TextBlock Text="Uninstall" VerticalAlignment="Center"
                     Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
          <Button DockPanel.Dock="Right" Width="40" Height="28" Click="Close_Click"
                  Background="Transparent" BorderThickness="0" Cursor="Hand"
                  HorizontalAlignment="Right" VerticalAlignment="Center">
            <Path Width="9" Height="9" Stretch="Uniform" Stroke="{StaticResource MutedBrush}" StrokeThickness="1.3"
                  Data="M0,0 L1,1 M1,0 L0,1"/>
          </Button>
        </DockPanel>
      </Border>

      <Grid Grid.Row="1" Margin="22,16,22,18">
        <!-- Confirm -->
        <StackPanel x:Name="PanelConfirm">
          <TextBlock Text="Remove Display Profile Manager?" FontSize="18" FontWeight="SemiBold"
                     Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
          <TextBlock Margin="0,10,0,0" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"
                     Text="This will uninstall the app from your PC. Your profiles in AppData are kept."/>
          <Border Margin="0,16,0,0" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="12">
            <StackPanel>
              <TextBlock Text="Install location" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
              <TextBlock x:Name="TxtPath" Margin="0,4,0,0" Foreground="{StaticResource TextBrush}"
                         TextWrapping="Wrap" FontSize="12"/>
            </StackPanel>
          </Border>
          <TextBlock x:Name="TxtMissing" Margin="0,10,0,0" Foreground="#E891A8" TextWrapping="Wrap" Visibility="Collapsed"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
            <Button Content="Cancel" Style="{StaticResource GhostButton}" Margin="0,0,8,0" Click="Close_Click"/>
            <Button x:Name="BtnUninstall" Content="Uninstall" Style="{StaticResource AccentButton}" Click="Uninstall_Click"/>
          </StackPanel>
        </StackPanel>

        <!-- Working -->
        <StackPanel x:Name="PanelWork" Visibility="Collapsed" VerticalAlignment="Center">
          <Grid Width="28" Height="28" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5" Margin="0,0,0,14">
            <Grid.RenderTransform>
              <RotateTransform x:Name="SpinRotate"/>
            </Grid.RenderTransform>
            <Ellipse Width="28" Height="28" Stroke="#33C45C84" StrokeThickness="2.5"/>
            <Path Stroke="{StaticResource AccentBrush}" StrokeThickness="2.5"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Data="M 14,2 A 12,12 0 1 1 2,14"/>
          </Grid>
          <TextBlock x:Name="TxtStatus" Text="Removing…" HorizontalAlignment="Center"
                     Foreground="{StaticResource TextBrush}"/>
        </StackPanel>

        <!-- Success -->
        <StackPanel x:Name="PanelDone" Visibility="Collapsed" VerticalAlignment="Center" Opacity="0">
          <Border Width="56" Height="56" CornerRadius="28" HorizontalAlignment="Center" Margin="0,0,0,14"
                  Background="#2A1C23" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1.5"
                  RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
              <ScaleTransform x:Name="CheckScale" ScaleX="0.6" ScaleY="0.6"/>
            </Border.RenderTransform>
            <Path Width="22" Height="22" Stretch="Uniform" Stroke="{StaticResource AccentHoverBrush}" StrokeThickness="2.2"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                  Data="M0,6 L4,10 L12,1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="Uninstalled" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center"
                     Foreground="{StaticResource TextBrush}"/>
          <TextBlock Margin="0,8,0,0" TextAlignment="Center" HorizontalAlignment="Center"
                     Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"
                     Text="Thanks for trying Display Profile Manager.&#10;made by Nakidev"/>
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</Window>
