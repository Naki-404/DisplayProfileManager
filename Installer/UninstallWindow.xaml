<Window x:Class="DisplayProfileManager.Setup.UninstallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uninstall Display Profile Manager"
        Width="480" Height="360"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI" FontSize="13"
        Icon="pack://application:,,,/Assets/app.ico"
        Loaded="Window_Loaded">
  <Border x:Name="Chrome" CornerRadius="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
          Background="{StaticResource BgBrush}" Opacity="0" RenderTransformOrigin="0.5,0.5">
    <Border.RenderTransform>
      <ScaleTransform x:Name="ChromeScale" ScaleX="0.94" ScaleY="0.94"/>
    </Border.RenderTransform>
    <Border.Effect>
      <DropShadowEffect BlurRadius="32" ShadowDepth="6" Opacity="0.5" Color="#000000"/>
    </Border.Effect>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="48"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Background="{StaticResource TitleBarBrush}" CornerRadius="16,16,0,0"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <DockPanel Margin="14,0,8,0">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Image Width="18" Height="18" Margin="0,0,8,0" Stretch="Uniform"
                   Source="pack://application:,,,/Assets/app.ico"/>
            <TextBlock Text="Uninstall" VerticalAlignment="Center"
                       Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
          </StackPanel>
          <Button DockPanel.Dock="Right" Width="36" Height="28" Click="Close_Click"
                  Style="{StaticResource CaptionCloseButton}"
                  HorizontalAlignment="Right" VerticalAlignment="Center">
            <Path Width="9" Height="9" Stretch="Uniform" Stroke="{StaticResource MutedBrush}" StrokeThickness="1.3"
                  Data="M0,0 L1,1 M1,0 L0,1"/>
          </Button>
        </DockPanel>
      </Border>

      <Grid Grid.Row="1" Margin="24,18,24,20">
        <StackPanel x:Name="PanelConfirm" Opacity="0">
          <TextBlock Text="Remove Display Profile Manager?" FontSize="20" FontWeight="SemiBold"
                     Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
          <TextBlock Margin="0,10,0,0" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"
                     Text="Uninstalls the app and restores neutral display settings. Your profiles in AppData are kept."/>
          <Border Margin="0,18,0,0" Background="{StaticResource PanelBrush}" CornerRadius="12" Padding="14"
                  BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <StackPanel>
              <TextBlock Text="Install location" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
              <TextBlock x:Name="TxtPath" Margin="0,6,0,0" Foreground="{StaticResource TextBrush}"
                         TextWrapping="Wrap" FontSize="12"/>
            </StackPanel>
          </Border>
          <TextBlock x:Name="TxtMissing" Margin="0,12,0,0" Foreground="{StaticResource DangerBrush}"
                     TextWrapping="Wrap" Visibility="Collapsed"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button Content="Cancel" Style="{StaticResource GhostButton}" Margin="0,0,8,0" Click="Close_Click"/>
            <Button x:Name="BtnUninstall" Content="Uninstall" Style="{StaticResource DangerButton}" Click="Uninstall_Click"/>
          </StackPanel>
        </StackPanel>

        <StackPanel x:Name="PanelWork" Visibility="Collapsed" VerticalAlignment="Center">
          <Grid Width="30" Height="30" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5" Margin="0,0,0,16">
            <Grid.RenderTransform>
              <RotateTransform x:Name="SpinRotate"/>
            </Grid.RenderTransform>
            <Ellipse Width="30" Height="30" Stroke="#337EB8D4" StrokeThickness="2.4"/>
            <Path Stroke="{StaticResource AccentBrush}" StrokeThickness="2.4"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Data="M 15,2 A 13,13 0 1 1 2,15"/>
          </Grid>
          <TextBlock x:Name="TxtStatus" Text="Removing…" HorizontalAlignment="Center"
                     Foreground="{StaticResource TextBrush}"/>
        </StackPanel>

        <StackPanel x:Name="PanelDone" Visibility="Collapsed" VerticalAlignment="Center" Opacity="0">
          <Border Width="60" Height="60" CornerRadius="30" HorizontalAlignment="Center" Margin="0,0,0,16"
                  Background="#1E2732" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1.5"
                  RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
              <ScaleTransform x:Name="CheckScale" ScaleX="0.5" ScaleY="0.5"/>
            </Border.RenderTransform>
            <Path Width="22" Height="22" Stretch="Uniform" Stroke="{StaticResource AccentHoverBrush}" StrokeThickness="2.2"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                  Data="M0,6 L4,10 L12,1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="Uninstalled" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center"
                     Foreground="{StaticResource TextBrush}"/>
          <TextBlock Margin="0,8,0,0" TextAlignment="Center" HorizontalAlignment="Center"
                     Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"
                     Text="Display settings restored.&#10;Thanks — made by Nakidev"/>
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</Window>
