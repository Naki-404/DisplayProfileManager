<Window x:Class="DisplayProfileManager.Setup.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Display Profile Manager Setup"
        Width="520" Height="420"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI" FontSize="13"
        Loaded="Window_Loaded">
  <Border x:Name="Chrome" CornerRadius="14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
          Background="{StaticResource BgBrush}" Opacity="0">
    <Border.Effect>
      <DropShadowEffect BlurRadius="28" ShadowDepth="4" Opacity="0.55" Color="#000000"/>
    </Border.Effect>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="44"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Title bar -->
      <Border Grid.Row="0" Background="{StaticResource TitleBarBrush}" CornerRadius="14,14,0,0"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <DockPanel Margin="14,0,6,0">
          <TextBlock Text="Display Profile Manager Setup" VerticalAlignment="Center"
                     Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
          <Button DockPanel.Dock="Right" Width="40" Height="28" Click="Close_Click"
                  Background="Transparent" BorderThickness="0" Cursor="Hand"
                  HorizontalAlignment="Right" VerticalAlignment="Center">
            <Path Width="9" Height="9" Stretch="Uniform" Stroke="{StaticResource MutedBrush}" StrokeThickness="1.3"
                  Data="M0,0 L1,1 M1,0 L0,1"/>
          </Button>
        </DockPanel>
      </Border>

      <!-- Body -->
      <Grid Grid.Row="1" Margin="22,14,22,8">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
          <TextBlock Text="Display Profile Manager" FontSize="22" FontWeight="SemiBold"
                     Foreground="{StaticResource TextBrush}"/>
          <TextBlock Margin="0,6,0,0" Foreground="{StaticResource MutedBrush}"
                     Text="Version 1.4.0  ·  by Nakidev"/>
          <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}" FontSize="12"
                     Text="Compact single-file install — same look as the app."/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,14">
          <TextBlock Text="Install folder" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"/>
          <DockPanel>
            <Button DockPanel.Dock="Right" Content="…" Style="{StaticResource GhostButton}"
                    Width="44" Margin="8,0,0,0" Padding="0,6" Click="Browse_Click"/>
            <TextBox x:Name="TxtPath"/>
          </DockPanel>
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="14" Margin="0,0,0,12">
          <StackPanel>
            <CheckBox x:Name="ChkStartMenu" Content="Start Menu shortcut" IsChecked="True"/>
            <CheckBox x:Name="ChkDesktop" Content="Desktop shortcut" IsChecked="False"/>
            <CheckBox x:Name="ChkLaunch" Content="Launch after install" IsChecked="True" Margin="0"/>
          </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" VerticalAlignment="Bottom">
          <TextBlock x:Name="TxtRuntime" Text="" Foreground="#E891A8" TextWrapping="Wrap" Margin="0,0,0,6"/>
          <TextBlock x:Name="TxtStatus" Text="" Foreground="{StaticResource MutedBrush}"/>
        </StackPanel>
      </Grid>

      <!-- Footer -->
      <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="22,12">
        <DockPanel>
          <TextBlock DockPanel.Dock="Left" Text="made by Nakidev" VerticalAlignment="Center"
                     Foreground="{StaticResource AccentHoverBrush}" FontSize="11" Opacity="0.9"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource GhostButton}" Margin="0,0,8,0" Click="Close_Click"/>
            <Button x:Name="BtnInstall" Content="Install" Style="{StaticResource AccentButton}" Click="Install_Click"/>
          </StackPanel>
        </DockPanel>
      </Border>
    </Grid>
  </Border>
</Window>
