<Window x:Class="DisplayProfileManager.Setup.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Display Profile Manager Setup"
        Width="540" Height="460"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI" FontSize="13"
        Loaded="Window_Loaded">
  <Border x:Name="Chrome" CornerRadius="14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
          Background="{StaticResource BgBrush}" Opacity="0"
          RenderTransformOrigin="0.5,0.5">
    <Border.RenderTransform>
      <ScaleTransform x:Name="ChromeScale" ScaleX="0.96" ScaleY="0.96"/>
    </Border.RenderTransform>
    <Border.Effect>
      <DropShadowEffect BlurRadius="28" ShadowDepth="4" Opacity="0.55" Color="#000000"/>
    </Border.Effect>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="44"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Background="{StaticResource TitleBarBrush}" CornerRadius="14,14,0,0"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <DockPanel Margin="14,0,6,0">
          <TextBlock Text="Display Profile Manager Setup" VerticalAlignment="Center"
                     Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
          <Button DockPanel.Dock="Right" Width="40" Height="28" Click="Close_Click"
                  Background="Transparent" BorderThickness="0" Cursor="Hand"
                  HorizontalAlignment="Right" VerticalAlignment="Center">
            <Path Width="9" Height="9" Stretch="Uniform" Stroke="{StaticResource MutedBrush}" StrokeThickness="1.3"
                  Data="M0,0 L1,1 M1,0 L0,1"/>
          </Button>
        </DockPanel>
      </Border>

      <Grid Grid.Row="1" Margin="22,14,22,8">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
          <TextBlock Text="Display Profile Manager" FontSize="22" FontWeight="SemiBold"
                     Foreground="{StaticResource TextBrush}"/>
          <TextBlock Margin="0,6,0,0" Foreground="{StaticResource MutedBrush}"
                     Text="Version 1.6.0  ·  by Nakidev"/>
          <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}" FontSize="12" TextWrapping="Wrap"
                     Text="Installs into its own folder and registers in Apps &amp; Features."/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
          <TextBlock Text="Install location (parent folder)" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"/>
          <DockPanel>
            <Button DockPanel.Dock="Right" Content="…" Style="{StaticResource GhostButton}"
                    Width="44" Margin="8,0,0,0" Padding="0,6" Click="Browse_Click"/>
            <TextBox x:Name="TxtPath"/>
          </DockPanel>
          <TextBlock x:Name="TxtResolved" Margin="0,6,0,0" FontSize="11"
                     Foreground="{StaticResource AccentHoverBrush}" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="14" Margin="0,0,0,10">
          <StackPanel>
            <CheckBox x:Name="ChkStartMenu" Content="Start Menu shortcut" IsChecked="True"/>
            <CheckBox x:Name="ChkDesktop" Content="Desktop shortcut" IsChecked="False"/>
            <CheckBox x:Name="ChkLaunch" Content="Launch after install" IsChecked="True" Margin="0"/>
          </StackPanel>
        </Border>

        <!-- Install progress -->
        <Border x:Name="ProgressPanel" Grid.Row="3" Visibility="Collapsed" VerticalAlignment="Bottom"
                Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="14">
          <StackPanel>
            <DockPanel Margin="0,0,0,10">
              <Grid Width="22" Height="22" DockPanel.Dock="Left" Margin="0,0,10,0"
                    RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                  <RotateTransform x:Name="SpinRotate"/>
                </Grid.RenderTransform>
                <Ellipse Width="22" Height="22" Stroke="#33C45C84" StrokeThickness="2.5"/>
                <Path Stroke="{StaticResource AccentBrush}" StrokeThickness="2.5"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Data="M 11,2 A 9,9 0 1 1 2,11"/>
              </Grid>
              <TextBlock x:Name="TxtStatus" Text="Installing…" VerticalAlignment="Center"
                         Foreground="{StaticResource TextBrush}"/>
            </DockPanel>
            <Border Height="4" CornerRadius="2" Background="#2A1C24" ClipToBounds="True">
              <Border x:Name="ProgressFill" Width="80" HorizontalAlignment="Left" CornerRadius="2"
                      Background="{StaticResource AccentBrush}">
                <Border.RenderTransform>
                  <TranslateTransform x:Name="ProgressSlide" X="-80"/>
                </Border.RenderTransform>
              </Border>
            </Border>
          </StackPanel>
        </Border>

        <TextBlock x:Name="TxtRuntime" Grid.Row="3" VerticalAlignment="Bottom"
                   Text="" Foreground="#E891A8" TextWrapping="Wrap"/>
      </Grid>

      <!-- Footer -->
      <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="22,12">
        <DockPanel>
          <TextBlock DockPanel.Dock="Left" Text="made by Nakidev" VerticalAlignment="Center"
                     Foreground="{StaticResource AccentHoverBrush}" FontSize="11" Opacity="0.9"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnCancel" Content="Cancel" Style="{StaticResource GhostButton}" Margin="0,0,8,0" Click="Close_Click"/>
            <Button x:Name="BtnInstall" Content="Install" Style="{StaticResource AccentButton}" Click="Install_Click"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- Success overlay -->
      <Border x:Name="SuccessOverlay" Grid.RowSpan="3" Visibility="Collapsed" Opacity="0"
              Background="#E6120E11" CornerRadius="14">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="28">
          <Border Width="64" Height="64" CornerRadius="32" HorizontalAlignment="Center" Margin="0,0,0,16"
                  Background="#2A1C23" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1.5"
                  RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
              <ScaleTransform x:Name="SuccessCheckScale" ScaleX="0.5" ScaleY="0.5"/>
            </Border.RenderTransform>
            <Path Width="26" Height="26" Stretch="Uniform" Stroke="{StaticResource AccentHoverBrush}" StrokeThickness="2.4"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                  Data="M0,6 L4,10 L12,1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <TextBlock x:Name="TxtSuccessTitle" Text="Installed successfully" FontSize="20" FontWeight="SemiBold"
                     HorizontalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
          <TextBlock x:Name="TxtSuccessBody" Margin="0,10,0,0" TextAlignment="Center" HorizontalAlignment="Center"
                     Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" MaxWidth="360"
                     Text="Thank you for installing Display Profile Manager.&#10;Enjoy — made by Nakidev"/>
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</Window>
