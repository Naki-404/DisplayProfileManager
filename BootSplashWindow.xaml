<Window x:Class="DisplayProfileManager.BootSplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Display Profile Manager"
        Width="520" Height="360"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        Topmost="True">
    <Window.Resources>
        <Storyboard x:Key="BootStory">
            <DoubleAnimation Storyboard.TargetName="Card" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX"
                             From="0.94" To="1" Duration="0:0:0.45">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY"
                             From="0.94" To="1" Duration="0:0:0.45">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Soft float of illustration -->
            <DoubleAnimation Storyboard.TargetName="ArtFloat" Storyboard.TargetProperty="Y"
                             From="10" To="0" Duration="0:0:0.7" BeginTime="0:0:0.1">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Art" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5" BeginTime="0:0:0.05"/>

            <!-- Ambient glow pulse -->
            <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity"
                             From="0.15" To="0.55" Duration="0:0:0.9" BeginTime="0:0:0.2"
                             AutoReverse="True" RepeatBehavior="2x"/>

            <DoubleAnimation Storyboard.TargetName="BrandTitle" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35" BeginTime="0:0:0.45"/>
            <DoubleAnimation Storyboard.TargetName="Subtitle" Storyboard.TargetProperty="Opacity"
                             From="0" To="0.9" Duration="0:0:0.3" BeginTime="0:0:0.6"/>

            <!-- Gentle exit -->
            <DoubleAnimation Storyboard.TargetName="Card" Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.35" BeginTime="0:0:1.85"/>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX"
                             From="1" To="1.03" Duration="0:0:0.35" BeginTime="0:0:1.85"/>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY"
                             From="1" To="1.03" Duration="0:0:0.35" BeginTime="0:0:1.85"/>
        </Storyboard>
    </Window.Resources>

    <Border x:Name="Card" CornerRadius="18" Margin="12" Opacity="0"
            BorderBrush="#4A3340" BorderThickness="1"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="CardScale" ScaleX="0.94" ScaleY="0.94"/>
        </Border.RenderTransform>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1E151A" Offset="0"/>
                <GradientStop Color="#140F13" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="36" ShadowDepth="6" Opacity="0.55" Color="#000000"/>
        </Border.Effect>

        <Grid ClipToBounds="True">
            <!-- Ambient glow -->
            <Ellipse x:Name="Glow" Width="280" Height="160" Opacity="0.2"
                     HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-20,0,40">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#88C45C84" Offset="0"/>
                        <GradientStop Color="#00C45C84" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <StackPanel VerticalAlignment="Center" Margin="24,18,24,18">
                <Grid Height="200" Margin="0,0,0,8">
                    <Border CornerRadius="12" ClipToBounds="True">
                        <Image x:Name="Art" Stretch="UniformToFill" Opacity="0"
                               RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <TranslateTransform x:Name="ArtFloat" Y="10"/>
                            </Image.RenderTransform>
                        </Image>
                    </Border>
                </Grid>

                <TextBlock x:Name="BrandTitle" Text="Display Profile Manager"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="#F8EAF0" HorizontalAlignment="Center" Opacity="0"/>
                <TextBlock x:Name="Subtitle" Text="Getting your desk ready…"
                           FontSize="12" Foreground="#B08A9A"
                           HorizontalAlignment="Center" Margin="0,4,0,0" Opacity="0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
